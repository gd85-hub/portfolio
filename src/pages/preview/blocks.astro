---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseBlocks from '../../components/blocks/CaseBlocks.astro';
import type { CaseBlock } from '../../data/cases';

const demoBlocks: CaseBlock[] = [
  {
    type: 'prose',
    heading: 'Prose block',
    body: 'A short text block for case context, problem framing, process notes, or outcome details.',
  },
  {
    type: 'imageText',
    side: 'left',
    image: '/photo-1454117096348-e4abbeba002c.avif',
    alt: 'Abstract layered texture used to preview an image-left case block',
    caption: 'Image left with caption.',
    heading: 'Image and text - image left',
    body: 'Use this block when a visual needs a short explanation next to it. On mobile the visual stacks above the text.',
  },
  {
    type: 'imageText',
    side: 'right',
    image: '/photo-1585854467604-cf2080ccef31.avif',
    alt: 'Abstract surface detail used to preview an image-right case block',
    caption: 'Image right with caption.',
    heading: 'Image and text - image right',
    body: 'The same content pattern can flip sides on desktop while keeping the mobile order simple.',
  },
  {
    type: 'fullImage',
    image: '/photo-1655841439659-0afc60676b70.avif',
    alt: 'Abstract full-width image used to preview a case image block',
    caption: 'Full image block with a real test image for the lightbox.',
  },
  {
    type: 'metrics',
    heading: 'Metrics block',
    items: [
      { value: '50+', label: 'screens documented' },
      { value: '60+', label: 'competitors audited' },
      { value: '8', label: 'pilots reviewed' },
      { value: '2', label: 'roles supported' },
    ],
  },
  {
    type: 'beforeAfter',
    before: '/photo-1663970206579-c157cba7edda.avif',
    after: '/photo-1669295384050-a1d4357bd1d7.avif',
    beforeAlt: 'Abstract before image used to preview a comparison block',
    afterAlt: 'Abstract after image used to preview a comparison block',
    caption: 'Before and after comparison with placeholders.',
  },
  {
    type: 'callout',
    variant: 'insight',
    body: 'This finding changed the direction of the case and should be visible before the reader gets into the detail.',
  },
  {
    type: 'callout',
    variant: 'problem',
    body: 'This is the blocking issue or constraint that explains why the following design decision mattered.',
  },
  {
    type: 'callout',
    variant: 'insight',
    title: 'Design decision',
    body: 'A custom title can replace the default label while keeping the same icon, layout, and visual treatment.',
  },
  {
    type: 'list',
    heading: 'Bulleted list',
    items: [
      'Research signal from interviews and product usage.',
      'Interface decision tied to a concrete workflow.',
      'Outcome or open question that belongs in the case.',
    ],
  },
  {
    type: 'list',
    heading: 'Ordered list',
    ordered: true,
    items: [
      'Map the current state.',
      'Find the broken decision point.',
      'Design and test the simplified flow.',
    ],
  },
  {
    type: 'quote',
    quote: 'The useful version of a case study explains the decision, not just the screen.',
    attribution: 'Internal writing note',
  },
  {
    type: 'twoCol',
    heading: 'Two-column comparison',
    left: {
      label: 'Before',
      body: 'Scattered signals, unclear ownership, and a workflow that asked users to remember too much.',
    },
    right: {
      label: 'After',
      body: 'Grouped decisions, clearer state, and a path that kept the next action close to the data.',
    },
  },
  {
    type: 'divider',
    label: 'Phase 2',
    title: 'From research signal to interface direction',
  },
  {
    type: 'divider',
    title: 'A divider without an eyebrow label',
  },
  {
    type: 'gallery',
    heading: 'Gallery block',
    columns: 3,
    items: [
      { image: '/photo-1672750771479-5ea73e9439ce.avif', alt: 'Abstract gallery image for dashboard state preview', caption: 'Dashboard state' },
      { image: '/premium_photo-1670793631008-7b01f8f7c5ce.avif', alt: 'Abstract gallery image for detail view preview', caption: 'Detail view' },
      { image: '/premium_photo-1671308539073-ebf8985a6a11.avif', alt: 'Abstract gallery image for empty state preview', caption: 'Empty state' },
      { image: '/premium_photo-1671995576541-a63078fa3063.avif', alt: 'Abstract gallery image for flow step preview', caption: 'Flow step' },
      { image: '/premium_photo-1672346462394-1073fbae6aa0.avif', alt: 'Abstract gallery image for component variant preview', caption: 'Component variant' },
      { image: '/premium_photo-1681400745727-c69f8e47f524.avif', alt: 'Abstract gallery image for final screen preview', caption: 'Final screen' },
    ],
  },
  {
    type: 'table',
    heading: 'Comparison',
    columns: ['', 'Option A', 'Option B'],
    rows: [
      { cells: ['Scope', 'Short placeholder text for one side.', 'Short placeholder text for another side.'] },
      { cells: ['Effort', 'A compact note for comparison.', 'A second compact note for comparison.'] },
    ],
  },
];
---

<BaseLayout
  title="Block library (internal) - Gleb Dvoryatkin"
  description="Internal block library preview."
  robots="noindex,nofollow"
>
  <main class="mx-auto max-w-content px-5 py-16 sm:px-8">
    <header class="mb-12 max-w-3xl">
      <h1 class="t-title text-ink">Block library (internal)</h1>
      <p class="t-body mt-4 text-body">Internal preview page for case-study content blocks.</p>
    </header>
    <CaseBlocks blocks={demoBlocks} />
  </main>
</BaseLayout>
