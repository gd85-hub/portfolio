---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Page not found - Gleb Dvoryatkin" description="Page not found">
  <main class="mx-auto flex min-h-[calc(100vh-4rem)] max-w-content items-center px-5 py-24 sm:px-8">
    <section class="max-w-2xl">
      <h1 class="t-title text-ink">Page not found</h1>
      <p class="t-body mt-4 text-body">The page you are looking for does not exist.</p>
      <div class="mt-8">
        <Button href="/">Back to home</Button>
      </div>
    </section>
  </main>
</BaseLayout>
