---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import SelectedWork from '../components/sections/SelectedWork.astro';
import WhatIDo from '../components/sections/WhatIDo.astro';
import Contact from '../components/sections/Contact.astro';

const title = 'Gleb Dvoryatkin - Product Designer';
const description = 'Product designer turning dense, complex products into clear interfaces. Fintech, sales, and edtech.';
---

<BaseLayout title={title} description={description}>
  <main>
    <Hero />
    <SelectedWork />
    <WhatIDo />
    <Contact />
  </main>
</BaseLayout>
