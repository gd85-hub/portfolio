---
import WorkCard from '../WorkCard.astro';
import { caseStudies } from '../../data/cases';
---

<section id="work" class="mx-auto max-w-content scroll-mt-20 px-5 py-16 sm:px-8">
  <h2 class="reveal mb-10 t-section text-ink">Selected work</h2>
  <div class="space-y-5 sm:space-y-6">
    {
      caseStudies.map((caseStudy) => (
        <WorkCard
          href={`/case/${caseStudy.slug}`}
          kicker={caseStudy.kicker}
          title={caseStudy.title}
          desc={caseStudy.cardDesc}
          time={caseStudy.time}
          role={caseStudy.role}
        />
      ))
    }
  </div>
</section>
