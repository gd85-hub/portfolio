---
import Button from '../Button.astro';
import Eyebrow from '../Eyebrow.astro';
---

<section class="mx-auto max-w-content px-5 pb-6 pt-12 sm:px-8 sm:pt-16">
  <div class="reveal max-w-2xl">
    <Eyebrow class="mb-5">Product Designer</Eyebrow>
    <h1 class="t-display text-ink">
      Turning dense, complex<br />products into clear interfaces.
    </h1>
    <p class="t-lede mt-6 max-w-[48ch] text-body">
      Product designer with 5+ years in UX and a decade in marketing and research. Fintech, sales, and edtech.
    </p>
    <div class="mt-9 flex flex-wrap items-center gap-4">
      <Button href="#contact" data-nav="home">
        Get in touch
      </Button>
    </div>
  </div>
</section>
