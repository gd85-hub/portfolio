---
import CopyEmail from '../CopyEmail.astro';

const email = 'gleb.dvoryatkin86@gmail.com';
const telegramUrl = 'https://t.me/virbonus825';
---

<section id="contact" class="panel scroll-mt-20 border-t border-line bg-inv">
  <div class="mx-auto max-w-content px-5 py-20 sm:px-8">
    <div class="reveal max-w-[52ch]">
      <h2 class="t-title text-inv-fg">Let's talk.</h2>
      <p class="t-lede mt-4 text-inv-sub">Open to senior product design roles and selected fintech advisory.</p>
      <div class="mt-8 flex flex-wrap items-center gap-5">
        <CopyEmail email={email} class="t-lede text-inv-fg" />
        <a href={telegramUrl} target="_blank" rel="noopener noreferrer" class="link-underline t-lede text-inv-fg">Telegram</a>
      </div>
    </div>
  </div>
</section>
