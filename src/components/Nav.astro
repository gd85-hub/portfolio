---
import Button from './Button.astro';
---

<header class="sticky top-0 z-40 border-b border-line bg-paper">
  <nav class="mx-auto flex h-16 max-w-content items-center justify-between px-5 sm:px-8">
    <a href="/" class="whitespace-nowrap font-mono text-[12px] font-medium leading-4 text-ink sm:text-[16px] sm:leading-6">Gleb Dvoryatkin<span class="text-accent">.</span></a>
    <div class="flex items-center gap-4 t-body text-muted sm:gap-7">
      <a href="/#work" class="link-underline hover:text-ink">Work</a>
      <a href="/about" class="link-underline hover:text-ink">About</a>
      <a href="/resume" class="link-underline hover:text-ink">Resume</a>
      <Button href="/#contact" variant="ghost" size="sm" class="hidden sm:inline-flex">Let's talk</Button>
      <button id="theme-toggle" aria-label="Toggle theme" class="grid h-8 w-8 place-items-center rounded-full border border-line text-ink transition-colors hover:border-ink"></button>
    </div>
  </nav>
</header>

<script is:inline>
  const toggle = document.getElementById('theme-toggle');
  const ICON_SUN = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"/></svg>';
  const ICON_MOON = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/></svg>';

  function syncIcon(){
    const dark = document.documentElement.classList.contains('dark');
    toggle.innerHTML = dark ? ICON_SUN : ICON_MOON;
  }

  syncIcon();
  toggle.addEventListener('click', () => {
    const dark = document.documentElement.classList.toggle('dark');
    try {
      localStorage.setItem('theme', dark ? 'dark' : 'light');
    } catch(e){}
    syncIcon();
  });
</script>
