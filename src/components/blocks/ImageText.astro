---
import Eyebrow from '../Eyebrow.astro';

interface Props {
  side: 'left' | 'right';
  image: string | null;
  alt: string;
  caption?: string;
  heading?: string;
  body: string;
}

const { side, image, alt, caption, heading, body } = Astro.props;
const imageOrder = side === 'right' ? 'md:order-2' : '';
const textOrder = side === 'right' ? 'md:order-1' : '';
---

<section class="grid gap-8 md:grid-cols-2 md:items-center">
  <figure class:list={[imageOrder]}>
    {
      image ? (
        <div class="overflow-hidden rounded-[var(--radius)] border border-line">
          <img src={image} alt={alt} data-zoomable class="h-auto w-full cursor-pointer" />
        </div>
      ) : (
        <div class="ph aspect-[16/9] w-full overflow-hidden rounded-[var(--radius)] border border-line">
          <div class="flex h-full items-center justify-center">
            <Eyebrow tone="ph" as="span">[ image ]</Eyebrow>
          </div>
        </div>
      )
    }
    {caption && <figcaption class="mt-3 max-w-[70ch] t-small text-muted">{caption}</figcaption>}
  </figure>
  <div class:list={['max-w-[70ch] space-y-3', textOrder]}>
    {heading && <h2 class="t-sub text-ink">{heading}</h2>}
    <p class="t-body text-body">{body}</p>
  </div>
</section>
