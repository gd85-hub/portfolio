---
import Prose from './Prose.astro';
import ImageText from './ImageText.astro';
import FullImage from './FullImage.astro';
import Metrics from './Metrics.astro';
import BeforeAfter from './BeforeAfter.astro';
import Callout from './Callout.astro';
import List from './List.astro';
import Quote from './Quote.astro';
import TwoCol from './TwoCol.astro';
import Divider from './Divider.astro';
import Gallery from './Gallery.astro';
import type { CaseBlock, CaseBodyBlock } from '../../data/cases';

interface Props {
  blocks: CaseBodyBlock[];
}

const { blocks } = Astro.props;

const normalizedBlocks: CaseBlock[] = blocks.map((block) => {
  if ('type' in block) {
    return block;
  }

  return {
    type: 'prose',
    heading: block.h,
    body: block.p,
  };
});
---

<div class="space-y-16">
  {normalizedBlocks.map((block) => {
    switch (block.type) {
      case 'prose':
        return <Prose heading={block.heading} body={block.body} />;
      case 'imageText':
        return <ImageText side={block.side} image={block.image} alt={block.alt} caption={block.caption} heading={block.heading} body={block.body} />;
      case 'fullImage':
        return <FullImage image={block.image} alt={block.alt} caption={block.caption} />;
      case 'metrics':
        return <Metrics heading={block.heading} items={block.items} />;
      case 'beforeAfter':
        return <BeforeAfter before={block.before} after={block.after} beforeAlt={block.beforeAlt} afterAlt={block.afterAlt} caption={block.caption} />;
      case 'callout':
        return <Callout body={block.body} variant={block.variant} />;
      case 'list':
        return <List heading={block.heading} ordered={block.ordered} items={block.items} />;
      case 'quote':
        return <Quote quote={block.quote} attribution={block.attribution} />;
      case 'twoCol':
        return <TwoCol heading={block.heading} left={block.left} right={block.right} />;
      case 'divider':
        return <Divider label={block.label} title={block.title} />;
      case 'gallery':
        return <Gallery heading={block.heading} columns={block.columns} items={block.items} />;
    }
  })}
</div>
