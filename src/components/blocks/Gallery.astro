---
import Eyebrow from '../Eyebrow.astro';
import type { GalleryItem } from '../../data/cases';

interface Props {
  heading?: string;
  columns?: 2 | 3;
  items: GalleryItem[];
}

const { heading, columns = 3, items } = Astro.props;
const gridClass = columns === 2 ? 'sm:grid-cols-2' : 'sm:grid-cols-2 lg:grid-cols-3';
---

<section>
  {heading && <h2 class="mb-6 t-sub text-ink">{heading}</h2>}
  <div class:list={['grid gap-6', gridClass]}>
    {items.map((item) => (
      <figure>
        {
          item.image ? (
            <img src={item.image} alt={item.alt} class="aspect-[4/3] w-full rounded-2xl border border-line object-cover" />
          ) : (
            <div class="ph aspect-[4/3] w-full overflow-hidden rounded-2xl border border-line">
              <div class="flex h-full items-center justify-center">
                <Eyebrow tone="ph" as="span">[ image ]</Eyebrow>
              </div>
            </div>
          )
        }
        {item.caption && <figcaption class="mt-3 t-small text-muted">{item.caption}</figcaption>}
      </figure>
    ))}
  </div>
</section>
