---
import Eyebrow from '../Eyebrow.astro';
import type { TwoColContent } from '../../data/cases';

interface Props {
  heading?: string;
  left: TwoColContent;
  right: TwoColContent;
}

const { heading, left, right } = Astro.props;
---

<section>
  {heading && <h2 class="mb-6 t-sub text-ink">{heading}</h2>}
  <div class="grid gap-8 md:grid-cols-2">
    <div class="max-w-[70ch]">
      {left.label && <Eyebrow class="mb-3">{left.label}</Eyebrow>}
      <p class="t-body text-body">{left.body}</p>
    </div>
    <div class="max-w-[70ch]">
      {right.label && <Eyebrow class="mb-3">{right.label}</Eyebrow>}
      <p class="t-body text-body">{right.body}</p>
    </div>
  </div>
</section>
