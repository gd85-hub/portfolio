---
import Eyebrow from '../Eyebrow.astro';

interface Props {
  before: string | null;
  after: string | null;
  beforeAlt: string;
  afterAlt: string;
  caption?: string;
}

const { before, after, beforeAlt, afterAlt, caption } = Astro.props;
---

<figure>
  <div class="grid gap-6 md:grid-cols-2">
    <div>
      <Eyebrow class="mb-3">Before</Eyebrow>
      {
        before ? (
          <img src={before} alt={beforeAlt} data-zoomable class="aspect-[4/3] w-full cursor-pointer rounded-[var(--radius)] border border-line object-cover" />
        ) : (
          <div class="ph aspect-[4/3] w-full overflow-hidden rounded-[var(--radius)] border border-line">
            <div class="flex h-full items-center justify-center">
              <Eyebrow tone="ph" as="span">[ before ]</Eyebrow>
            </div>
          </div>
        )
      }
    </div>
    <div>
      <Eyebrow class="mb-3">After</Eyebrow>
      {
        after ? (
          <img src={after} alt={afterAlt} data-zoomable class="aspect-[4/3] w-full cursor-pointer rounded-[var(--radius)] border border-line object-cover" />
        ) : (
          <div class="ph aspect-[4/3] w-full overflow-hidden rounded-[var(--radius)] border border-line">
            <div class="flex h-full items-center justify-center">
              <Eyebrow tone="ph" as="span">[ after ]</Eyebrow>
            </div>
          </div>
        )
      }
    </div>
  </div>
  {caption && <figcaption class="mt-3 t-small text-muted">{caption}</figcaption>}
</figure>
