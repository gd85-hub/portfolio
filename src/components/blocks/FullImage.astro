---
import Eyebrow from '../Eyebrow.astro';

interface Props {
  image: string | null;
  alt: string;
  caption?: string;
}

const { image, alt, caption } = Astro.props;
---

<figure>
  {
    image ? (
      <img src={image} alt={alt} class="aspect-[16/9] w-full rounded-2xl border border-line object-cover" />
    ) : (
      <div class="ph aspect-[16/9] w-full overflow-hidden rounded-2xl border border-line">
        <div class="flex h-full items-center justify-center">
          <Eyebrow tone="ph" as="span">[ image ]</Eyebrow>
        </div>
      </div>
    )
  }
  {caption && <figcaption class="mt-3 t-small text-muted">{caption}</figcaption>}
</figure>
