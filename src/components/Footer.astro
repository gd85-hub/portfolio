---
import CopyEmail from './CopyEmail.astro';

const email = 'gleb.dvoryatkin86@gmail.com';
const telegramUrl = 'https://t.me/virbonus825';
---

<footer class="bg-inv">
  <div class="mx-auto grid max-w-content gap-3 border-t border-inv-line px-5 py-8 text-[12px] text-inv-sub sm:grid-cols-[1fr_auto_1fr] sm:items-center sm:px-8">
    <span class="font-mono">Gleb Dvoryatkin - Novi Sad</span>
    <div class="flex flex-wrap items-center gap-4 font-mono sm:justify-self-center">
      <CopyEmail email={email} class="t-small text-inv-sub" />
      <a href={telegramUrl} target="_blank" rel="noopener noreferrer" class="link-underline t-small text-inv-sub">Telegram</a>
    </div>
    <span class="sm:justify-self-end">&copy; 2026</span>
  </div>
</footer>
