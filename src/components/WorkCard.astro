---
import Eyebrow from './Eyebrow.astro';

interface Props {
  kicker: string;
  title: string;
  desc: string;
  time: string;
  role: string;
  href?: string;
  class?: string;
  [key: string]: unknown;
}

const {
  kicker,
  title,
  desc,
  time,
  role,
  href = '#',
  class: className,
  ...attrs
} = Astro.props;
---

<a href={href} class:list={['reveal group grid overflow-hidden rounded-[var(--radius)] border border-line bg-surface md:grid-cols-[1.15fr_.85fr] md:items-stretch', className]} {...attrs}>
  <div class="min-w-0 overflow-hidden">
    <div class="ph relative flex aspect-[16/9] items-center justify-center transition-transform duration-[var(--motion-base)] ease-[var(--ease-standard)] group-hover:scale-[1.02]">
      <Eyebrow tone="ph" as="span">[ cover ]</Eyebrow>
      <span class="pointer-events-none absolute inset-0 bg-black/5 opacity-0 transition-opacity duration-[var(--motion-base)] ease-[var(--ease-standard)] group-hover:opacity-100"></span>
    </div>
  </div>
  <div class="flex min-w-0 flex-col gap-3 p-6 sm:p-8">
    <div class="flex flex-col gap-3">
      <Eyebrow tone="accent">{kicker}</Eyebrow>
      <h3 class="t-section text-ink">{title}</h3>
      <p class="t-small text-muted">{time} &middot; {role}</p>
      <p class="t-body text-body">{desc}</p>
    </div>
    <span class="t-body mt-auto inline-flex items-center gap-1.5 font-medium text-ink">
      <span class="link-underline group-hover:[background-size:100%_1px]">Read case</span>
      <span class="icon transition-transform group-hover:translate-x-1">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </span>
    </span>
  </div>
</a>
